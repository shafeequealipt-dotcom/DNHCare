# ---- DNH Care blog agent — copy to ".env" on the Oracle VM and fill in ----
#
# Telegram creds are read from SYSTEM env vars (already set on the user's machine):
#   DNH_Telegram_Token   (bot token from @BotFather)
#   DNH_Telegram_ID      (your numeric chat id from @userinfobot)
# On the Oracle VM, export those two (or add them here as a fallback).

# OpenRouter (content generation — OpenAI-compatible). Already set in system env here.
OPENROUTER_API_KEY=sk-or-...
# Optional: override the default free model (also switchable live via Telegram /setmodel)
DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# GitHub: a fine-grained PAT with "Contents: Read and write" on the DNHCare repo
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=shafeequealipt-dotcom/DNHCare

# Local working clone the bot commits from (absolute path on the VM)
REPO_DIR=/opt/dnhcare/DNHCare

# Daily post time, 24h, in IST (Asia/Kolkata). e.g. 06:00
POST_TIME=06:00
